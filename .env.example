# --- Frontend (Vite) — build / Vercel ---
# Public URL of the Render API (no trailing slash)
VITE_API_URL=https://your-service.onrender.com

# --- Backend (Render) — copy to Render Environment ---
NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://user:pass@host:5432/dbname

JWT_ACCESS_SECRET=min-16-chars-random
SESSION_SECRET=min-16-chars-random

# Browser origin where the SPA is hosted (Vercel), no trailing slash
FRONTEND_ORIGIN=https://your-app.vercel.app

# Same as this API’s public URL when frontend and API are on different hosts (Vercel + Render).
# OAuth redirect URIs must use this host in Google/GitHub consoles.
API_PUBLIC_URL=https://your-service.onrender.com

# Optional OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
